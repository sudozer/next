             <underline>true</underline>
            </font>
           </property>
           <property name="toolTip">
            <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Packet Structures define the format a packet will arrive in for processing.  Telemetry definitions are the building blocks of packet structures.  All of the header and packet formats are defined via telemetry definitions, and assembled into a packet structure.  The assembled packet structure must account for every bit of data contained in a packet recieved over an interface.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
           </property>
           <property name="text">
            <string>Telemetry structures</string>
           </property>
