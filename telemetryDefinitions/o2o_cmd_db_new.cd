    "4228": {
        "packetName": "ce_transferFile",
        "description": "Initiates a file transfer between the CE and the ground segment. Any response from this command should not be sent back to the ground segment until after the file transfer completes, whether successful or not.",
        "apid": 484,
        "packetId": 4228,
        "fields": [
            {
                "fieldName": "transmissionMode",
                "type": "uint8_t",
                "description": "The transmission mode to use for this transfer unacknowledged class 1 or acknowledged class 2.",
