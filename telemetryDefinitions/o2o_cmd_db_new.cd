                "bitLength": 8
            },
            {
                "fieldName": "fromEntityId",
                "type": "uint16_t",
                "description": "The entity from which the file is to be sent.",
                "defaultSetting": 55,
                "bitLength": 16
            },
            {
                "fieldName": "toEntityId",
                "type": "uint16_t",
                "description": "The entity to which the file is to be received.",
