    "8454": {
        "packetName": "mm_spacewireInterface",
        "description": "The SpaceWire interface summary. This packet will be generated every 5s.",
        "apid": 1591,
        "packetId": 8454,
        "fields": [
            {
                "fieldName": "packetCount",
                "type": "uint16_t",
                "description": "Packet counter.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "cmdSeqNum",
                "type": "uint16_t",
                "description": "Command sequence number.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "reserved1",
                "description": "Reserved padding.",
                "type": "uint8_t",
                "arrayLength": 2,
                "defaultSetting": [
                    0,
                    0
                ],
                "bitLength": 16,
                "bitstructType": "u8u8"
            },
            {
                "fieldName": "numFlowControlErrors",
                "type": "uint16_t",
                "description": "Count of flow control errors detected at the link layer.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "numLineTimeoutErrors",
                "type": "uint16_t",
                "description": "Count of line timeout errors detected at the link layer.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "numLinkResets",
                "type": "uint16_t",
                "description": "Count of times the SpaceWire link has been reset.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "numErrEndOfPacketRecvd",
                "type": "uint16_t",
                "description": "Count of error-end-of-packet messages received at the link layer.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "numPacketsReceived",
                "type": "uint32_t",
                "description": "Count of packets received by the MM on the interface.",
                "units": "count",
                "bitLength": 32,
                "bitstructType": "u32"
            },
            {
                "fieldName": "numPacketsTransmitted",
                "type": "uint32_t",
                "description": "Count of packets transmitted by the MM on the interface.",
                "units": "count",
                "bitLength": 32,
                "bitstructType": "u32"
            },
            {
                "fieldName": "numBadTlas",
                "type": "uint16_t",
                "description": "Count of packets received with an invalid TLA in the SpaceWire header.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "numBadSpacewireProtocolIds",
                "type": "uint16_t",
                "description": "Count of packets received with an invalid Protocol ID in the SpaceWire header.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "numCrcErroredCmds",
                "type": "uint16_t",
                "description": "Count of packets received with a CRC error (and thus not counted as accepted commands or queued for processing).",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "reserved2",
                "description": "Reserved padding.",
                "type": "uint8_t",
                "arrayLength": 2,
                "defaultSetting": [
                    0,
                    0
                ],
                "bitLength": 16,
                "bitstructType": "u8u8"
            },
            {
                "fieldName": "numFailedCmds",
                "type": "uint16_t",
                "description": "Count of commands that passed syntax validation and were queued for processing, but failed during execution. This includes, but is not limited to, invalid commands for the current system state, arguments out-of-range, internal logic errors, register read/write failures.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "numInvalidCmds",
                "type": "uint16_t",
                "description": "Count of commands received that failed initial syntax checking. This includes unknown command IDs or command argument values.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "numAcceptedCmds",
                "type": "uint32_t",
                "description": "Count of commands that passed CRC and syntax validation and were accepted and queued for processing.",
                "units": "count",
                "bitLength": 32,
                "bitstructType": "u32"
            },
            {
                "fieldName": "numPendingCmds",
                "type": "uint8_t",
                "description": "Count of commands pending in queue in the queue to be processed.",
                "units": "count",
                "bitLength": 8,
                "bitstructType": "u8"
            },
            {
                "fieldName": "reserved3",
                "description": "Reserved padding.",
                "type": "uint8_t",
                "bitLength": 8,
                "bitstructType": "u8"
            },
            {
                "fieldName": "seqNumLastCmdAccepted",
                "type": "uint16_t",
                "description": "The sequence number of the last command that was accepted for processing.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "seqNumLastSuccessfulCmd",
                "type": "uint16_t",
                "description": "The sequence number of the last command that was accepted and passed during processing.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "seqNumLastFailedCmd",
                "type": "uint16_t",
                "description": "The sequence number of the last command that was accepted but failed during processing.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "checksum",
                "type": "uint32_t",
                "description": "Packet checksum.",
                "defaultSetting": 0,
                "units": "chksum",
                "bitLength": 32,
                "bitstructType": "u32"
            }
        ]
    },
