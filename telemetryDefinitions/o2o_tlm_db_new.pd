    "4354": {
        "packetName": "ce_spaceWire",
        "description": "This packet comprises of SpaceWire status and MM cmd & tlm statistics. This packet can be sent at slow  rate.",
        "apid": 1591,
        "packetId": 4354,
        "fields": [
            {
                "fieldName": "packetCount",
                "type": "uint16_t",
                "description": "Packet counter.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "ceCmdSentCount",
                "type": "uint16_t",
                "description": "The number of command packets sent to the modem (excluding time, doppler, and file transfers).",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "mmTlmReceivedCount",
                "type": "uint16_t",
                "description": "The number of telemetry packets received from the modem.",
                "units": "count",
                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "mmTlmDroppedCount",
                "type": "uint16_t",
                "description": "The number of telemetry packets dropped due to CRC or length errors.",
