                "bitLength": 16,
                "bitstructType": "u16"
            },
            {
                "fieldName": "spwErrCount",
                "type": "uint16_t",
                "description": "The number of SpaceWire errors detected.",
                "bitLength": 16,
                "bitstructType": "u16"
            },
