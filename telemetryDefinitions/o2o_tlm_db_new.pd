    "8700": {
        "packetName": "mm_derivedStats",
        "description": "This packet is a statistics packet that is derived from other source telemetry, generally communications performance telemetry from the mm_dataSummaryPeriodic packet; the reason for having this packet is that Bob wanted to be able to integrate comm performance for longer than 1 second, but the counters are only in mm_dataSummaryPeriodic, which is not reset clearable, so it requires some statistical processing engine to keep track across an ensemble of such packets.",
        "apid": 1591,
        "packetId": 8700,
        "fields": [
            {
                "fieldName": "ber1sAvg",
                "type": "float",
                "description": "BER (bit error rate) averaged over the last 1 second.",
                "bitLength": 32,
                "bitstructType": "f32"
            },
            {
                "fieldName": "ber10sAvg",
                "type": "float",
                "description": "BER (bit error rate) averaged over the last 10 seconds.",
                "bitLength": 32,
                "bitstructType": "f32"
            },
            {
                "fieldName": "ber100sAvg",
                "type": "float",
                "description": "BER (bit error rate) averaged over the last 100 seconds.",
                "bitLength": 32,
                "bitstructType": "f32"
            },
            {
                "fieldName": "ser1sAvg",
                "type": "float",
                "description": "SER (symbol error rate) averaged over the last 1 second.",
                "bitLength": 32,
                "bitstructType": "f32"
            },
            {
                "fieldName": "ser10sAvg",
                "type": "float",
                "description": "SER (symbol error rate) averaged over the last 10 seconds.",
                "bitLength": 32,
                "bitstructType": "f32"
            },
            {
                "fieldName": "ser100sAvg",
                "type": "float",
                "description": "SER (symbol error rate) averaged over the last 100 seconds.",
                "bitLength": 32,
                "bitstructType": "f32"
            }
        ]
    },
